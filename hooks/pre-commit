#!/bin/sh
# Abort commit if any staged C/H file (outside vendor/) is not clang-formatted.
# Install with: make hooks

CLANG_FORMAT=$(command -v clang-format \
    || echo /Library/Developer/CommandLineTools/usr/bin/clang-format)

if [ ! -x "$CLANG_FORMAT" ]; then
    echo "pre-commit: clang-format not found, skipping format check"
    exit 0
fi

FILES=$(git diff --cached --name-only --diff-filter=ACMR \
    | grep -E '\.(c|h)$' \
    | grep -v '^vendor/')

[ -z "$FILES" ] && exit 0

FAIL=0
for f in $FILES; do
    if ! "$CLANG_FORMAT" --dry-run -Werror "$f" 2>/dev/null; then
        echo "  not formatted: $f"
        FAIL=1
    fi
done

if [ "$FAIL" -eq 1 ]; then
    echo ""
    echo "Fix with: make fmt"
    exit 1
fi
