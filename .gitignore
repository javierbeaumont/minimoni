# User-facing binaries (built at repo root for distribution)
minimoni
minimoni-migrate
minimoni-linux-*
minimoni-migrate-linux-*

# Generated build outputs — everything `make`/`make debug`/`make test` emits
# (embed.h, minimoni-debug, unit-test, etc.) goes into build/.
build/

# Vendored library build tree (sub-make's output)
vendor/bearssl/build/

# Local dev scratchpad — preview configs, test DBs, anything ephemeral.
# Convention: anything not for distribution and not a build artefact lives here.
.dev/
